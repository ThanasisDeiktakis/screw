# ─── Screw Spot configuration ─────────────────────────────────────────────────
#
# Copy this file to .env and fill in the values:
#   cp example.env .env
#
# JWT and VAPID keys are generated automatically on first run
# if .env does not exist. You can leave them empty.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Server ───────────────────────────────────────────────────────────────────

# Port Spot listens on (default 8080)
PORT=8080

# Serve client static files (PWA) directly from Spot.
# 0 = enabled (default) — convenient for development and simple setups
# where client and Spot share the same domain.
# Set to 1 if static files are served by nginx/CDN from a separate domain.
DISABLE_STATIC=0


# ─── JWT ──────────────────────────────────────────────────────────────────────

# HMAC-SHA256 secret for signing JWT tokens.
# Auto-generated on first run.
# Changing it invalidates all active client sessions (will require re-login).
JWT_SECRET=


# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────

# Keys for sending push notifications via the browser Web Push API.
# Auto-generated on first run.
# Changing them invalidates all existing push subscriptions —
# users will need to re-subscribe in settings.
VAPID_PUBLIC=
VAPID_PRIVATE=

# Admin email — required by the Web Push standard (sent in VAPID header).
# Not published or used anywhere else.
VAPID_CONTACT=mailto:admin@example.com


# ─── S3-compatible storage (file transfers) ──────────────────────────────────
# Leave empty to disable file uploads.
#
# Authentication uses a static access key (Access Key + Secret).
# IAM tokens and temporary credentials are not supported —
# presigned URLs require a static signing key.
#
# Endpoint examples (https:// is added automatically, can be omitted):
#   Selectel:           s3.ru-3.storage.selcloud.ru    (region: ru-3)
#   AWS S3:             s3.amazonaws.com               (region: us-east-1 etc.)
#   Cloudflare R2:      <account_id>.r2.cloudflarestorage.com  (region: auto)
#   MinIO (local):      localhost:9000                 (region: any)
#
# Bucket CORS must allow your domain origin, Methods: GET, PUT, HEAD

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=screw-files
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Public bucket domain for download links (optional).
# If not set — links are built using the S3_ENDPOINT host.
# Example: https://{uuid}.selstorage.ru
S3_PUBLIC_URL=

# File retention period in days (should match the lifecycle rule in the bucket).
# Files are deleted by S3 itself — Spot only informs clients via expires_at.
S3_FILE_TTL_DAYS=7

# Maximum file size for upload in bytes (default 50 MB)
S3_MAX_FILE_SIZE=52428800

# Proxy file traffic through nginx (default 0 — client connects to S3 directly).
# If 1 — presigned URLs are returned as relative paths /files/put/ and /files/get/,
# which nginx proxies to S3. The client never sees the real storage domain.
# Requires nginx configuration — see docs/files.md
S3_PROXY_MODE=0
