#
# Copy this file to .env and fill in the values:
#   cp example.env .env
#
# JWT and VAPID keys are generated automatically on first run
# if .env does not exist. You can leave them empty.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────

PORT=8080

# Serve client static files from Spot.
# 0 = enabled (default), 1 = disabled (when using nginx/CDN).
DISABLE_STATIC=0

# ─── JWT ──────────────────────────────────────────────────────────────────────

# HMAC-SHA256 secret for JWT tokens. Auto-generated on first run.
JWT_SECRET=

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────

# Auto-generated on first run.
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_CONTACT=mailto:admin@example.com

# ─── S3-compatible storage (file transfers) ──────────────────────────────────
# Leave empty to disable file uploads.

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=screw-files
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=
S3_FILE_TTL_DAYS=7
S3_MAX_FILE_SIZE=52428800
